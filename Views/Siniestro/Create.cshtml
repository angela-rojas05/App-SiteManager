@model SiteManager.Models.Siniestro
@{
    ViewData["Title"] = "Nuevo Siniestro";
}

<div class="sm-form-card">
    <div class="sm-form-header">
        <h2><i class="fa-solid fa-triangle-exclamation" style="color:#ef4444;margin-right:8px;"></i>Registrar Nuevo Siniestro</h2>
        <p>Completa los campos para crear un nuevo expediente</p>
    </div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="sm-form-body" style="padding-bottom:0;gap:4px;">
            <span style="font-size:12px;color:#ef4444;"></span>
        </div>
        <div class="sm-form-body">
            <div class="sm-field">
                <label asp-for="TipoDanio">Tipo de Daño *</label>
                <input asp-for="TipoDanio" placeholder="Ej. Filtración de agua en techo" />
                <span asp-validation-for="TipoDanio" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="Direccion">Dirección *</label>
                <input asp-for="Direccion" placeholder="Edificio, apartamento, sector" />
                <span asp-validation-for="Direccion" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="Descripcion">Descripción</label>
                <textarea asp-for="Descripcion" placeholder="Describe la extensión del daño, materiales afectados, causa probable..."></textarea>
                <span asp-validation-for="Descripcion" class="sm-field-error"></span>
            </div>
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="Estado">Estado</label>
                    <select asp-for="Estado" asp-items="Html.GetEnumSelectList<SiteManager.Models.EstadoSiniestro>()"></select>
                </div>
                <div class="sm-field">
                    <label asp-for="ClienteId">Cliente *</label>
                    <select asp-for="ClienteId" asp-items='new SelectList(ViewBag.Clientes, "Id", "Nombre")'>
                        <option value="">— Seleccione un cliente —</option>
                    </select>
                    <span asp-validation-for="ClienteId" class="sm-field-error"></span>
                </div>
            </div>
        </div>
        <div class="sm-form-footer">
            <button type="submit" class="btn-sm-primary"><i class="fa-solid fa-floppy-disk"></i> Guardar</button>
            <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}