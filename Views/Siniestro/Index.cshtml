@model IEnumerable<SiteManager.Models.Siniestro>
@{
    ViewData["Title"] = "Siniestros";
}

<h2 class="mb-4">Lista de Siniestros</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo Siniestro</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tipo de Daño</th>
            <th>Dirección</th>
            <th>Estado</th>
            <th>Cliente</th>
            <th>Fecha Registro</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.TipoDanio</td>
                <td>@item.Direccion</td>
                <td>
                    <span class="badge bg-@(item.Estado.ToString() == "Cerrado" ? "success" : item.Estado.ToString() == "Levantamiento" ? "secondary" : "primary")">
                        @item.Estado
                    </span>
                </td>
                <td>@(item.Cliente?.Nombre ?? "Sin asignar")</td>
                <td>@item.FechaRegistro.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>