@model IEnumerable<SiteManager.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <h2 style="font-size:15px;font-weight:700;margin-bottom:2px;">Lista de Usuarios</h2>
        <p style="font-size:12px;color:var(--muted-fg);margin:0;">@Model.Count() registros encontrados</p>
    </div>
    <a asp-action="Create" class="btn-sm-primary">
        <i class="fa-solid fa-plus"></i> Nuevo Usuario
    </a>
</div>

<div class="sm-card" style="overflow:hidden;">
    <table class="sm-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Usuario</th>
                <th>Nombre Completo</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="id-badge">#@item.Id.ToString().PadLeft(3, '0')</span></td>
                    <td>
                        <div style="display:flex;align-items:center;gap:8px;">
                            <div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#0d9488,#059669);display:flex;align-items:center;justify-content:center;color:white;font-size:11px;font-weight:700;flex-shrink:0;">
                                @item.NombreCompleto.Substring(0, 1).ToUpper()
                            </div>
                            <span style="font-weight:600;font-size:13px;">@item.NombreUsuario</span>
                        </div>
                    </td>
                    <td style="font-size:13px;">@item.NombreCompleto</td>
                    <td style="font-size:12px;color:var(--muted-fg);">@item.Correo</td>
                    <td>
                        <span style="font-size:11px;background:#f3f4f6;color:#374151;padding:3px 10px;border-radius:6px;font-weight:600;">
                            @item.Rol
                        </span>
                    </td>
                    <td>
                        @if (item.Activo)
                        {
                            <span class="badge-estado badge-completado"><span class="badge-dot"></span>Activo</span>
                        }
                        else
                        {
                            <span class="badge-estado badge-cancelado"><span class="badge-dot"></span>Inactivo</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-sm-icon view" title="Ver"><i class="fa-solid fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-sm-icon edit" title="Editar"><i class="fa-solid fa-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-sm-icon danger" title="Eliminar"><i class="fa-solid fa-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>