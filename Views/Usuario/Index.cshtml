@model IEnumerable<SiteManager.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<h2 class="mb-4">Lista de Usuarios</h2>

<p>
    <a asp-action="Create" class="btn btn-dark">Nuevo Usuario</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Nombre Completo</th>
            <th>Correo</th>
            <th>Rol</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.NombreUsuario</td>
                <td>@item.NombreCompleto</td>
                <td>@item.Correo</td>
                <td><span class="badge bg-secondary">@item.Rol</span></td>
                <td>
                    <span class="badge bg-@(item.Activo ? "success" : "danger")">
                        @(item.Activo ? "Activo" : "Inactivo")
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>