@model SiteManager.Models.Usuario
@{
    ViewData["Title"] = "Detalle del Usuario";
}

<div class="sm-detail-card">
    <div class="sm-detail-header">
        <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#0d9488,#059669);display:flex;align-items:center;justify-content:center;color:white;font-size:14px;font-weight:700;">
                @Model.NombreCompleto.Substring(0, 1).ToUpper()
            </div>
            <h2 style="margin:0;">@Model.NombreCompleto</h2>
        </div>
        @if (Model.Activo)
        {
            <span class="badge-estado badge-completado"><span class="badge-dot"></span>Activo</span>
        }
        else
        {
            <span class="badge-estado badge-cancelado"><span class="badge-dot"></span>Inactivo</span>
        }
    </div>
    <div class="sm-detail-grid">
        <div class="sm-detail-field">
            <div class="sm-detail-label">Nombre de Usuario</div>
            <div class="sm-detail-value" style="font-family:monospace;">@Model.NombreUsuario</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Rol</div>
            <div class="sm-detail-value">
                <span style="font-size:11px;background:#f3f4f6;color:#374151;padding:3px 10px;border-radius:6px;font-weight:600;">@Model.Rol</span>
            </div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Correo</div>
            <div class="sm-detail-value">@Model.Correo</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Teléfono</div>
            <div class="sm-detail-value">@Model.Telefono</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Fecha de Registro</div>
            <div class="sm-detail-value" style="font-family:monospace;">@Model.FechaRegistro.ToShortDateString()</div>
        </div>
    </div>
    <div class="sm-detail-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-sm-primary"><i class="fa-solid fa-pencil"></i> Editar</a>
        <a asp-action="Index" class="btn-sm-ghost"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>
</div>