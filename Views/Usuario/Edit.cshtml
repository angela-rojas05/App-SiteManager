@model SiteManager.Models.Usuario
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="sm-form-card">
    <div class="sm-form-header">
        <h2><i class="fa-solid fa-pencil" style="color:#d97706;margin-right:8px;"></i>Editar Usuario <span style="font-family:monospace;color:var(--muted-fg);">#@Model.Id.ToString().PadLeft(3, '0')</span></h2>
        <p>Modifica los datos del usuario</p>
    </div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="FechaRegistro" />
        <div asp-validation-summary="ModelOnly" class="sm-field-error" style="padding:12px 24px;"></div>
        <div class="sm-form-body">
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="NombreUsuario">Nombre de Usuario *</label>
                    <input asp-for="NombreUsuario" />
                    <span asp-validation-for="NombreUsuario" class="sm-field-error"></span>
                </div>
                <div class="sm-field">
                    <label asp-for="Contrasena">Contraseña *</label>
                    <input asp-for="Contrasena" type="password" />
                    <span asp-validation-for="Contrasena" class="sm-field-error"></span>
                </div>
            </div>
            <div class="sm-field">
                <label asp-for="NombreCompleto">Nombre Completo *</label>
                <input asp-for="NombreCompleto" />
                <span asp-validation-for="NombreCompleto" class="sm-field-error"></span>
            </div>
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="Correo">Correo Electrónico</label>
                    <input asp-for="Correo" type="email" />
                    <span asp-validation-for="Correo" class="sm-field-error"></span>
                </div>
                <div class="sm-field">
                    <label asp-for="Telefono">Teléfono</label>
                    <input asp-for="Telefono" />
                    <span asp-validation-for="Telefono" class="sm-field-error"></span>
                </div>
            </div>
            <div class="sm-field">
                <label asp-for="Rol">Rol</label>
                <select asp-for="Rol" asp-items="Html.GetEnumSelectList<SiteManager.Models.RolUsuario>()"></select>
            </div>
            <div class="sm-checkbox-field">
                <input asp-for="Activo" type="checkbox" />
                <label asp-for="Activo">Usuario Activo</label>
            </div>
        </div>
        <div class="sm-form-footer">
            <button type="submit" class="btn-sm-primary"><i class="fa-solid fa-floppy-disk"></i> Guardar Cambios</button>
            <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}