@model SiteManager.Models.Evidencia
@{
    ViewData["Title"] = "Detalle de Evidencia";
}

<h2>Detalle de Evidencia #@Model.Id</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Título</dt>
            <dd class="col-sm-9">@Model.Titulo</dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>

            <dt class="col-sm-3">Ruta del Archivo</dt>
            <dd class="col-sm-9">@Model.RutaArchivo</dd>

            <dt class="col-sm-3">Siniestro</dt>
            <dd class="col-sm-9">@(Model.Siniestro?.TipoDanio ?? "Sin asignar")</dd>

            <dt class="col-sm-3">Fecha de Subida</dt>
            <dd class="col-sm-9">@Model.FechaSubida.ToShortDateString()</dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>