@model SiteManager.Models.Evidencia
@{
    ViewData["Title"] = "Eliminar Evidencia";
}

<h2>Eliminar Evidencia</h2>

<h4>¿Está seguro de que desea eliminar esta evidencia?</h4>

<div class="card border-danger mt-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Título</dt>
            <dd class="col-sm-9">@Model.Titulo</dd>

            <dt class="col-sm-3">Ruta del Archivo</dt>
            <dd class="col-sm-9">@Model.RutaArchivo</dd>

            <dt class="col-sm-3">Siniestro</dt>
            <dd class="col-sm-9">@(Model.Siniestro?.TipoDanio ?? "Sin asignar")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>