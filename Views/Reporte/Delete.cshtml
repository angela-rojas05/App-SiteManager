@model SiteManager.Models.Reporte
@{
    ViewData["Title"] = "Eliminar Reporte";
}

<div class="sm-delete-card">
    <div class="sm-delete-header">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <h2>¿Eliminar este reporte?</h2>
    </div>
    <div class="sm-delete-body">
        <div class="sm-delete-row"><span>ID</span><span style="font-family:monospace;">#@Model.Id.ToString().PadLeft(3, '0')</span></div>
        <div class="sm-delete-row"><span>Título</span><span>@Model.Titulo</span></div>
        <div class="sm-delete-row"><span>Tipo</span><span>@Model.TipoReporte</span></div>
        <div class="sm-delete-row"><span>Siniestro</span><span>@(Model.Siniestro?.TipoDanio ?? "Sin asignar")</span></div>
        <div class="sm-delete-row"><span>Generado Por</span><span>@Model.GeneradoPor</span></div>
    </div>
    <div class="sm-delete-footer">
        <form asp-action="Delete" method="post" style="display:inline;">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-sm-danger"><i class="fa-solid fa-trash"></i> Eliminar</button>
        </form>
        <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
    </div>
</div>