@model SiteManager.Models.Reporte
@{
    ViewData["Title"] = "Detalle del Reporte";
}

<h2>Detalle del Reporte #@Model.Id</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Título</dt>
            <dd class="col-sm-9">@Model.Titulo</dd>

            <dt class="col-sm-3">Tipo</dt>
            <dd class="col-sm-9"><span class="badge bg-info">@Model.TipoReporte</span></dd>

            <dt class="col-sm-3">Contenido</dt>
            <dd class="col-sm-9">@Model.Contenido</dd>

            <dt class="col-sm-3">Siniestro</dt>
            <dd class="col-sm-9">@(Model.Siniestro?.TipoDanio ?? "Sin asignar")</dd>

            <dt class="col-sm-3">Generado Por</dt>
            <dd class="col-sm-9">@Model.GeneradoPor</dd>

            <dt class="col-sm-3">Fecha de Generación</dt>
            <dd class="col-sm-9">@Model.FechaGeneracion.ToShortDateString()</dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>