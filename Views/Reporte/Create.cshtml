@model SiteManager.Models.Reporte
@{
    ViewData["Title"] = "Nuevo Reporte";
}

<h2>Generar Nuevo Reporte</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label">Título</label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Contenido" class="form-label">Contenido</label>
        <textarea asp-for="Contenido" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Contenido" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TipoReporte" class="form-label">Tipo de Reporte</label>
        <input asp-for="TipoReporte" class="form-control" placeholder="Levantamiento, Cotización, Final, etc." />
        <span asp-validation-for="TipoReporte" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="GeneradoPor" class="form-label">Generado Por</label>
        <input asp-for="GeneradoPor" class="form-control" placeholder="Nombre del técnico o arquitecto" />
        <span asp-validation-for="GeneradoPor" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SiniestroId" class="form-label">Siniestro</label>
        <select asp-for="SiniestroId" class="form-select" asp-items='new SelectList(ViewBag.Siniestros, "Id", "TipoDanio")'>
            <option value="">-- Seleccione un siniestro --</option>
        </select>
        <span asp-validation-for="SiniestroId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-success">Guardar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}