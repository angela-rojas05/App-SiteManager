@model SiteManager.Models.Cotizacion
@{
    ViewData["Title"] = "Eliminar Cotización";
}

<h2>Eliminar Cotización</h2>

<h4>¿Está seguro de que desea eliminar esta cotización?</h4>

<div class="card border-danger mt-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Concepto</dt>
            <dd class="col-sm-9">@Model.Concepto</dd>

            <dt class="col-sm-3">Costo Estimado</dt>
            <dd class="col-sm-9">₡@Model.CostoEstimado.ToString("N2")</dd>

            <dt class="col-sm-3">Siniestro</dt>
            <dd class="col-sm-9">@(Model.Siniestro?.TipoDanio ?? "Sin asignar")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>