@model SiteManager.Models.Cotizacion
@{
    ViewData["Title"] = "Nueva Cotización";
}

<h2>Registrar Nueva Cotización</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Concepto" class="form-label">Concepto</label>
        <input asp-for="Concepto" class="form-control" />
        <span asp-validation-for="Concepto" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Materiales" class="form-label">Materiales</label>
        <textarea asp-for="Materiales" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Materiales" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CostoEstimado" class="form-label">Costo Estimado</label>
        <input asp-for="CostoEstimado" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="CostoEstimado" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CostoFinal" class="form-label">Costo Final</label>
        <input asp-for="CostoFinal" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="CostoFinal" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SiniestroId" class="form-label">Siniestro</label>
        <select asp-for="SiniestroId" class="form-select" asp-items='new SelectList(ViewBag.Siniestros, "Id", "TipoDanio")'>
            <option value="">-- Seleccione un siniestro --</option>
        </select>
        <span asp-validation-for="SiniestroId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-info">Guardar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}