@model SiteManager.Models.Cotizacion
@{
    ViewData["Title"] = "Nueva Cotización";
}

<div class="sm-form-card">
    <div class="sm-form-header">
        <h2><i class="fa-solid fa-file-invoice-dollar" style="color:#d97706;margin-right:8px;"></i>Registrar Nueva Cotización</h2>
        <p>Ingresa los costos estimados para el expediente</p>
    </div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="sm-field-error" style="padding:12px 24px;"></div>
        <div class="sm-form-body">
            <div class="sm-field">
                <label asp-for="Concepto">Concepto *</label>
                <input asp-for="Concepto" placeholder="Ej. Reparación de techo y pintura" />
                <span asp-validation-for="Concepto" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="Materiales">Materiales</label>
                <textarea asp-for="Materiales" placeholder="Lista los materiales necesarios..."></textarea>
                <span asp-validation-for="Materiales" class="sm-field-error"></span>
            </div>
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="CostoEstimado">Costo Estimado (₡) *</label>
                    <input asp-for="CostoEstimado" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="CostoEstimado" class="sm-field-error"></span>
                </div>
                <div class="sm-field">
                    <label asp-for="CostoFinal">Costo Final (₡)</label>
                    <input asp-for="CostoFinal" type="number" step="0.01" placeholder="0.00 (opcional)" />
                    <span asp-validation-for="CostoFinal" class="sm-field-error"></span>
                </div>
            </div>
            <div class="sm-field">
                <label asp-for="SiniestroId">Siniestro *</label>
                <select asp-for="SiniestroId" asp-items='new SelectList(ViewBag.Siniestros, "Id", "TipoDanio")'>
                    <option value="">— Seleccione un siniestro —</option>
                </select>
                <span asp-validation-for="SiniestroId" class="sm-field-error"></span>
            </div>
        </div>
        <div class="sm-form-footer">
            <button type="submit" class="btn-sm-primary"><i class="fa-solid fa-floppy-disk"></i> Guardar</button>
            <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}