@model SiteManager.Models.Material
@{
    ViewData["Title"] = "Nuevo Material";
}

<h2>Registrar Nuevo Material</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label">Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UnidadMedida" class="form-label">Unidad de Medida</label>
        <input asp-for="UnidadMedida" class="form-control" placeholder="m², kg, unidad, etc." />
        <span asp-validation-for="UnidadMedida" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PrecioUnitario" class="form-label">Precio Unitario</label>
        <input asp-for="PrecioUnitario" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="PrecioUnitario" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CantidadStock" class="form-label">Cantidad en Stock</label>
        <input asp-for="CantidadStock" class="form-control" type="number" />
        <span asp-validation-for="CantidadStock" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Proveedor" class="form-label">Proveedor</label>
        <input asp-for="Proveedor" class="form-control" />
        <span asp-validation-for="Proveedor" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SiniestroId" class="form-label">Siniestro (opcional)</label>
        <select asp-for="SiniestroId" class="form-select" asp-items='new SelectList(ViewBag.Siniestros, "Id", "TipoDanio")'>
            <option value="">-- Sin asignar --</option>
        </select>
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-secondary">Guardar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}