@model SiteManager.Models.Material
@{
    ViewData["Title"] = "Nuevo Material";
}

<div class="sm-form-card">
    <div class="sm-form-header">
        <h2><i class="fa-solid fa-boxes-stacked" style="color:#059669;margin-right:8px;"></i>Registrar Nuevo Material</h2>
        <p>Agrega un material al inventario</p>
    </div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="sm-field-error" style="padding:12px 24px;"></div>
        <div class="sm-form-body">
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="Nombre">Nombre *</label>
                    <input asp-for="Nombre" placeholder="Ej. Cemento Portland" />
                    <span asp-validation-for="Nombre" class="sm-field-error"></span>
                </div>
                <div class="sm-field">
                    <label asp-for="UnidadMedida">Unidad de Medida *</label>
                    <input asp-for="UnidadMedida" placeholder="m², kg, unidad, etc." />
                    <span asp-validation-for="UnidadMedida" class="sm-field-error"></span>
                </div>
            </div>
            <div class="sm-field">
                <label asp-for="Descripcion">Descripción</label>
                <textarea asp-for="Descripcion" placeholder="Descripción del material..."></textarea>
                <span asp-validation-for="Descripcion" class="sm-field-error"></span>
            </div>
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="PrecioUnitario">Precio Unitario (₡) *</label>
                    <input asp-for="PrecioUnitario" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="PrecioUnitario" class="sm-field-error"></span>
                </div>
                <div class="sm-field">
                    <label asp-for="CantidadStock">Cantidad en Stock *</label>
                    <input asp-for="CantidadStock" type="number" placeholder="0" />
                    <span asp-validation-for="CantidadStock" class="sm-field-error"></span>
                </div>
            </div>
            <div class="sm-field">
                <label asp-for="Proveedor">Proveedor</label>
                <input asp-for="Proveedor" placeholder="Nombre del proveedor" />
                <span asp-validation-for="Proveedor" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="SiniestroId">Siniestro (opcional)</label>
                <select asp-for="SiniestroId" asp-items='new SelectList(ViewBag.Siniestros, "Id", "TipoDanio")'>
                    <option value="">— Sin asignar —</option>
                </select>
            </div>
        </div>
        <div class="sm-form-footer">
            <button type="submit" class="btn-sm-primary"><i class="fa-solid fa-floppy-disk"></i> Guardar</button>
            <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}