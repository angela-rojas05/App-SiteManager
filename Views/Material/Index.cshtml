@model IEnumerable<SiteManager.Models.Material>
@{
    ViewData["Title"] = "Materiales";
}

<h2 class="mb-4">Lista de Materiales</h2>

<p>
    <a asp-action="Create" class="btn btn-secondary">Nuevo Material</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Unidad</th>
            <th>Precio Unitario</th>
            <th>Stock</th>
            <th>Proveedor</th>
            <th>Siniestro</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nombre</td>
                <td>@item.UnidadMedida</td>
                <td>₡@item.PrecioUnitario.ToString("N2")</td>
                <td>@item.CantidadStock</td>
                <td>@item.Proveedor</td>
                <td>@(item.Siniestro?.TipoDanio ?? "Sin asignar")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>