@model SiteManager.Models.Cliente
@{
    ViewData["Title"] = "Detalle del Cliente";
}

<h2>Detalle del Cliente #@Model.Id</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre @Model.Apellido</dd>

            <dt class="col-sm-3">Teléfono</dt>
            <dd class="col-sm-9">@Model.Telefono</dd>

            <dt class="col-sm-3">Correo</dt>
            <dd class="col-sm-9">@Model.Correo</dd>

            <dt class="col-sm-3">Dirección</dt>
            <dd class="col-sm-9">@Model.Direccion</dd>
        </dl>
    </div>
</div>

<h4 class="mt-4">Siniestros Asociados</h4>
@if (Model.Siniestros.Any())
{
    <table class="table table-sm table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tipo de Daño</th>
                <th>Dirección</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sin in Model.Siniestros)
            {
                <tr>
                    <td>@sin.Id</td>
                    <td>@sin.TipoDanio</td>
                    <td>@sin.Direccion</td>
                    <td>@sin.Estado</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No hay siniestros asociados.</p>
}

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>