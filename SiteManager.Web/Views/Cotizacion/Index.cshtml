@model IEnumerable<SiteManager.Domain.Models.Cotizacion>
@{
    ViewData["Title"] = "Cotizaciones";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <h2 style="font-size:15px;font-weight:700;margin-bottom:2px;">Lista de Cotizaciones</h2>
        <p style="font-size:12px;color:var(--muted-fg);margin:0;">@Model.Count() registros encontrados</p>
    </div>
    <a asp-action="Create" class="btn-sm-primary">
        <i class="fa-solid fa-plus"></i> Nueva Cotización
    </a>
</div>

<div class="sm-card" style="overflow:hidden;">
    <table class="sm-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Concepto</th>
                <th>Costo Estimado</th>
                <th>Costo Final</th>
                <th>Siniestro</th>
                <th>Fecha</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="id-badge">#@item.Id.ToString().PadLeft(3, '0')</span></td>
                    <td style="font-weight:600;">@item.Concepto</td>
                    <td style="font-family:monospace;font-size:13px;">₡@item.CostoEstimado.ToString("N2")</td>
                    <td>
                        @if (item.CostoFinal.HasValue)
                        {
                            <span style="font-family:monospace;font-size:13px;color:#059669;font-weight:600;">₡@item.CostoFinal.Value.ToString("N2")</span>
                        }
                        else
                        {
                            <span style="font-size:11px;background:#fef3c7;color:#d97706;padding:3px 8px;border-radius:6px;font-weight:600;">Pendiente</span>
                        }
                    </td>
                    <td style="font-size:12px;color:var(--muted-fg);">@(item.Siniestro?.TipoDanio ?? "Sin asignar")</td>
                    <td style="font-size:12px;color:var(--muted-fg);font-family:monospace;">@item.FechaCotizacion.ToShortDateString()</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-sm-icon view" title="Ver"><i class="fa-solid fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-sm-icon edit" title="Editar"><i class="fa-solid fa-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-sm-icon danger" title="Eliminar"><i class="fa-solid fa-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>