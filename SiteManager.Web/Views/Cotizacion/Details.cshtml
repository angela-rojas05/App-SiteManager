@model SiteManager.Domain.Models.Cotizacion
@{
    ViewData["Title"] = "Detalle de Cotización";
}

<div class="sm-detail-card">
    <div class="sm-detail-header">
        <h2><i class="fa-solid fa-file-invoice-dollar" style="color:#d97706;margin-right:8px;"></i>Cotización <span style="font-family:monospace;color:var(--muted-fg);">#@Model.Id.ToString().PadLeft(3, '0')</span></h2>
    </div>
    <div class="sm-detail-grid">
        <div class="sm-detail-field full">
            <div class="sm-detail-label">Concepto</div>
            <div class="sm-detail-value">@Model.Concepto</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Costo Estimado</div>
            <div class="sm-detail-value" style="font-family:monospace;font-size:15px;font-weight:700;">₡@Model.CostoEstimado.ToString("N2")</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Costo Final</div>
            <div class="sm-detail-value">
                @if (Model.CostoFinal.HasValue)
                {
                    <span style="font-family:monospace;font-size:15px;font-weight:700;color:#059669;">₡@Model.CostoFinal.Value.ToString("N2")</span>
                }
                else
                {
                    <span style="font-size:11px;background:#fef3c7;color:#d97706;padding:3px 10px;border-radius:6px;font-weight:600;">Pendiente</span>
                }
            </div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Siniestro</div>
            <div class="sm-detail-value">@(Model.Siniestro?.TipoDanio ?? "Sin asignar")</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Fecha de Cotización</div>
            <div class="sm-detail-value" style="font-family:monospace;">@Model.FechaCotizacion.ToShortDateString()</div>
        </div>
        <div class="sm-detail-field full">
            <div class="sm-detail-label">Materiales</div>
            <div class="sm-detail-value" style="line-height:1.6;">@Model.Materiales</div>
        </div>
    </div>
    <div class="sm-detail-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-sm-primary"><i class="fa-solid fa-pencil"></i> Editar</a>
        <a asp-action="Index" class="btn-sm-ghost"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>
</div>