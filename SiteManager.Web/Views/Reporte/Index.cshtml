@model IEnumerable<SiteManager.Domain.Models.Reporte>
@{
    ViewData["Title"] = "Reportes";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <h2 style="font-size:15px;font-weight:700;margin-bottom:2px;">Lista de Reportes</h2>
        <p style="font-size:12px;color:var(--muted-fg);margin:0;">@Model.Count() registros encontrados</p>
    </div>
    <a asp-action="Create" class="btn-sm-primary">
        <i class="fa-solid fa-plus"></i> Nuevo Reporte
    </a>
</div>

<div class="sm-card" style="overflow:hidden;">
    <table class="sm-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Título</th>
                <th>Tipo</th>
                <th>Siniestro</th>
                <th>Generado Por</th>
                <th>Fecha</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="id-badge">#@item.Id.ToString().PadLeft(3, '0')</span></td>
                    <td style="font-weight:600;">
                        <i class="fa-solid fa-chart-bar" style="color:#4f46e5;margin-right:6px;font-size:12px;"></i>
                        @item.Titulo
                    </td>
                    <td>
                        <span style="font-size:11px;background:#e0e7ff;color:#4f46e5;padding:3px 10px;border-radius:6px;font-weight:600;">
                            @item.TipoReporte
                        </span>
                    </td>
                    <td style="font-size:12px;color:var(--muted-fg);">@(item.Siniestro?.TipoDanio ?? "Sin asignar")</td>
                    <td style="font-size:12px;">@item.GeneradoPor</td>
                    <td style="font-size:12px;color:var(--muted-fg);font-family:monospace;">@item.FechaGeneracion.ToShortDateString()</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-sm-icon view" title="Ver"><i class="fa-solid fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-sm-icon edit" title="Editar"><i class="fa-solid fa-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-sm-icon danger" title="Eliminar"><i class="fa-solid fa-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>