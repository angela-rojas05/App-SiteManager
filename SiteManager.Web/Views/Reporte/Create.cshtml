@model SiteManager.Models.Reporte
@{
    ViewData["Title"] = "Nuevo Reporte";
}

<div class="sm-form-card">
    <div class="sm-form-header">
        <h2><i class="fa-solid fa-chart-bar" style="color:#4f46e5;margin-right:8px;"></i>Generar Nuevo Reporte</h2>
        <p>Documenta el levantamiento técnico del expediente</p>
    </div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="sm-field-error" style="padding:12px 24px;"></div>
        <div class="sm-form-body">
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="Titulo">Título *</label>
                    <input asp-for="Titulo" placeholder="Ej. Informe de levantamiento final" />
                    <span asp-validation-for="Titulo" class="sm-field-error"></span>
                </div>
                <div class="sm-field">
                    <label asp-for="TipoReporte">Tipo de Reporte *</label>
                    <input asp-for="TipoReporte" placeholder="Levantamiento, Cotización, Final..." />
                    <span asp-validation-for="TipoReporte" class="sm-field-error"></span>
                </div>
            </div>
            <div class="sm-field">
                <label asp-for="Contenido">Contenido *</label>
                <textarea asp-for="Contenido" placeholder="Describe los hallazgos, recomendaciones y conclusiones..." style="min-height:140px;"></textarea>
                <span asp-validation-for="Contenido" class="sm-field-error"></span>
            </div>
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="GeneradoPor">Generado Por *</label>
                    <input asp-for="GeneradoPor" placeholder="Nombre del técnico o arquitecto" />
                    <span asp-validation-for="GeneradoPor" class="sm-field-error"></span>
                </div>
                <div class="sm-field">
                    <label asp-for="SiniestroId">Siniestro *</label>
                    <select asp-for="SiniestroId" asp-items='new SelectList(ViewBag.Siniestros, "Id", "TipoDanio")'>
                        <option value="">— Seleccione un siniestro —</option>
                    </select>
                    <span asp-validation-for="SiniestroId" class="sm-field-error"></span>
                </div>
            </div>
        </div>
        <div class="sm-form-footer">
            <button type="submit" class="btn-sm-primary"><i class="fa-solid fa-floppy-disk"></i> Guardar</button>
            <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}