@model IEnumerable<SiteManager.Domain.Models.Material>
@{
    ViewData["Title"] = "Materiales";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <h2 style="font-size:15px;font-weight:700;margin-bottom:2px;">Lista de Materiales</h2>
        <p style="font-size:12px;color:var(--muted-fg);margin:0;">@Model.Count() registros encontrados</p>
    </div>
    <a asp-action="Create" class="btn-sm-primary">
        <i class="fa-solid fa-plus"></i> Nuevo Material
    </a>
</div>

<div class="sm-card" style="overflow:hidden;">
    <table class="sm-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Unidad</th>
                <th>Precio Unitario</th>
                <th>Stock</th>
                <th>Proveedor</th>
                <th>Siniestro</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var stockColor = item.CantidadStock <= 5 ? "#ef4444" : item.CantidadStock <= 20 ? "#d97706" : "#059669";
                <tr>
                    <td><span class="id-badge">#@item.Id.ToString().PadLeft(3, '0')</span></td>
                    <td style="font-weight:600;">
                        <i class="fa-solid fa-box" style="color:#059669;margin-right:6px;font-size:12px;"></i>
                        @item.Nombre
                    </td>
                    <td style="font-size:12px;color:var(--muted-fg);">@item.UnidadMedida</td>
                    <td style="font-family:monospace;font-size:13px;">₡@item.PrecioUnitario.ToString("N2")</td>
                    <td>
                        <span style="font-weight:700;color:@stockColor;font-size:13px;">@item.CantidadStock</span>
                    </td>
                    <td style="font-size:12px;color:var(--muted-fg);">@item.Proveedor</td>
                    <td style="font-size:12px;color:var(--muted-fg);">@(item.Siniestro?.TipoDanio ?? "Sin asignar")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-sm-icon view" title="Ver"><i class="fa-solid fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-sm-icon edit" title="Editar"><i class="fa-solid fa-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-sm-icon danger" title="Eliminar"><i class="fa-solid fa-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>