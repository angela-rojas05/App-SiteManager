@model SiteManager.Models.Material
@{
    ViewData["Title"] = "Eliminar Material";
}

<div class="sm-delete-card">
    <div class="sm-delete-header">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <h2>¿Eliminar este material?</h2>
    </div>
    <div class="sm-delete-body">
        <div class="sm-delete-row"><span>ID</span><span style="font-family:monospace;">#@Model.Id.ToString().PadLeft(3, '0')</span></div>
        <div class="sm-delete-row"><span>Nombre</span><span>@Model.Nombre</span></div>
        <div class="sm-delete-row"><span>Unidad</span><span>@Model.UnidadMedida</span></div>
        <div class="sm-delete-row"><span>Precio</span><span style="font-family:monospace;">₡@Model.PrecioUnitario.ToString("N2")</span></div>
        <div class="sm-delete-row"><span>Stock</span><span>@Model.CantidadStock</span></div>
    </div>
    <div class="sm-delete-footer">
        <form asp-action="Delete" method="post" style="display:inline;">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-sm-danger"><i class="fa-solid fa-trash"></i> Eliminar</button>
        </form>
        <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
    </div>
</div>