<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SiteManager</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <div class="sm-wrapper">

        <!-- Sidebar -->
        <aside class="sm-sidebar">
            <div class="sm-sidebar-logo">
                <div class="sm-logo-icon">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <div class="sm-logo-text">
                    <p>SiteManager</p>
                    <span>Gestión de Siniestros</span>
                </div>
            </div>

            <nav class="sm-nav">
                <p class="sm-nav-label">Módulos</p>
                <a asp-controller="Home" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#f0fdf4;color:#0d9488;">
                        <i class="fa-solid fa-gauge-high"></i>
                    </span>
                    Inicio
                </a>
                <a asp-controller="Siniestro" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Siniestro" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#fee2e2;color:#ef4444;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </span>
                    Siniestros
                </a>
                <a asp-controller="Cliente" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cliente" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#ede9fe;color:#7c3aed;">
                        <i class="fa-solid fa-users"></i>
                    </span>
                    Clientes
                </a>
                <a asp-controller="Evidencia" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Evidencia" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#e0f2fe;color:#0284c7;">
                        <i class="fa-solid fa-camera"></i>
                    </span>
                    Evidencias
                </a>
                <a asp-controller="Cotizacion" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cotizacion" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#fef3c7;color:#d97706;">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </span>
                    Cotizaciones
                </a>
                <a asp-controller="Material" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Material" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#d1fae5;color:#059669;">
                        <i class="fa-solid fa-boxes-stacked"></i>
                    </span>
                    Materiales
                </a>
                <a asp-controller="Reporte" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reporte" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#e0e7ff;color:#4f46e5;">
                        <i class="fa-solid fa-chart-bar"></i>
                    </span>
                    Reportes
                </a>
                <a asp-controller="Usuario" asp-action="Index"
                   class="sm-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuario" ? "active" : "")">
                    <span class="sm-nav-icon" style="background:#f3f4f6;color:#6b7280;">
                        <i class="fa-solid fa-user-gear"></i>
                    </span>
                    Usuarios
                </a>
            </nav>

            <div class="sm-sidebar-user">
                <div class="sm-user-card">
                    <div class="sm-user-avatar">AM</div>
                    <div>
                        <div class="sm-user-name">Admin</div>
                        <div class="sm-user-email">admin@sitemanager.com</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main content -->
        <div class="sm-main">
            <header class="sm-header">
                <h1>@(ViewData["Title"] ?? "SiteManager")</h1>
                <div class="sm-header-actions">
                    <div class="sm-search">
                        <span class="sm-search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" placeholder="Buscar..." />
                    </div>
                </div>
            </header>

            <main class="sm-content">
                @RenderBody()
            </main>

            <footer style="padding:12px 28px;border-top:1px solid var(--border);background:white;font-size:12px;color:var(--muted-fg);flex-shrink:0;">
                &copy; 2026 SiteManager — Gestión de Siniestros y Levantamientos
            </footer>
        </div>

    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>