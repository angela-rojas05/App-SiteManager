@model SiteManager.Domain.Models.Evidencia
@{
    ViewData["Title"] = "Detalle de Evidencia";
}

<div class="sm-detail-card">
    <div class="sm-detail-header">
        <h2><i class="fa-solid fa-camera" style="color:#0284c7;margin-right:8px;"></i>Evidencia <span style="font-family:monospace;color:var(--muted-fg);">#@Model.Id.ToString().PadLeft(3, '0')</span></h2>
    </div>
    <div class="sm-detail-grid">
        <div class="sm-detail-field">
            <div class="sm-detail-label">Título</div>
            <div class="sm-detail-value">@Model.Titulo</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Siniestro</div>
            <div class="sm-detail-value">@(Model.Siniestro?.TipoDanio ?? "Sin asignar")</div>
        </div>
        <div class="sm-detail-field full">
            <div class="sm-detail-label">Descripción</div>
            <div class="sm-detail-value" style="line-height:1.6;">@Model.Descripcion</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Ruta del Archivo</div>
            <div class="sm-detail-value" style="font-family:monospace;font-size:12px;">@Model.RutaArchivo</div>
        </div>
        <div class="sm-detail-field">
            <div class="sm-detail-label">Fecha de Subida</div>
            <div class="sm-detail-value" style="font-family:monospace;">@Model.FechaSubida.ToShortDateString()</div>
        </div>
    </div>
    <div class="sm-detail-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-sm-primary"><i class="fa-solid fa-pencil"></i> Editar</a>
        <a asp-action="Index" class="btn-sm-ghost"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>
</div>