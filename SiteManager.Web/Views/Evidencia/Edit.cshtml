@model SiteManager.Domain.Models.Evidencia
@{
    ViewData["Title"] = "Editar Evidencia";
}

<div class="sm-form-card">
    <div class="sm-form-header">
        <h2><i class="fa-solid fa-pencil" style="color:#d97706;margin-right:8px;"></i>Editar Evidencia <span style="font-family:monospace;color:var(--muted-fg);">#@Model.Id.ToString().PadLeft(3, '0')</span></h2>
        <p>Modifica los datos de la evidencia</p>
    </div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="FechaSubida" />
        <div asp-validation-summary="ModelOnly" class="sm-field-error" style="padding:12px 24px;"></div>
        <div class="sm-form-body">
            <div class="sm-field">
                <label asp-for="Titulo">Título *</label>
                <input asp-for="Titulo" />
                <span asp-validation-for="Titulo" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="Descripcion">Descripción</label>
                <textarea asp-for="Descripcion"></textarea>
                <span asp-validation-for="Descripcion" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="RutaArchivo">Ruta del Archivo</label>
                <input asp-for="RutaArchivo" />
                <span asp-validation-for="RutaArchivo" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="SiniestroId">Siniestro</label>
                <select asp-for="SiniestroId" asp-items='new SelectList(ViewBag.Siniestros, "Id", "TipoDanio")'>
                    <option value="">— Seleccione un siniestro —</option>
                </select>
                <span asp-validation-for="SiniestroId" class="sm-field-error"></span>
            </div>
        </div>
        <div class="sm-form-footer">
            <button type="submit" class="btn-sm-primary"><i class="fa-solid fa-floppy-disk"></i> Guardar Cambios</button>
            <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}