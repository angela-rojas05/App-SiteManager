@model IEnumerable<SiteManager.Models.Evidencia>
@{
    ViewData["Title"] = "Evidencias";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <h2 style="font-size:15px;font-weight:700;margin-bottom:2px;">Lista de Evidencias</h2>
        <p style="font-size:12px;color:var(--muted-fg);margin:0;">@Model.Count() registros encontrados</p>
    </div>
    <a asp-action="Create" class="btn-sm-primary">
        <i class="fa-solid fa-plus"></i> Nueva Evidencia
    </a>
</div>

<div class="sm-card" style="overflow:hidden;">
    <table class="sm-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Título</th>
                <th>Descripción</th>
                <th>Siniestro</th>
                <th>Fecha Subida</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="id-badge">#@item.Id.ToString().PadLeft(3, '0')</span></td>
                    <td style="font-weight:600;">
                        <i class="fa-solid fa-camera" style="color:#0284c7;margin-right:6px;font-size:12px;"></i>
                        @item.Titulo
                    </td>
                    <td style="font-size:12px;color:var(--muted-fg);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.Descripcion</td>
                    <td style="font-size:12px;">@(item.Siniestro?.TipoDanio ?? "Sin asignar")</td>
                    <td style="font-size:12px;color:var(--muted-fg);font-family:monospace;">@item.FechaSubida.ToShortDateString()</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-sm-icon view" title="Ver"><i class="fa-solid fa-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-sm-icon edit" title="Editar"><i class="fa-solid fa-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-sm-icon danger" title="Eliminar"><i class="fa-solid fa-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>