@model IEnumerable<SiteManager.Domain.Models.Siniestro>
@{
    ViewData["Title"] = "Siniestros";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <h2 style="font-size:15px;font-weight:700;margin-bottom:2px;">Lista de Siniestros</h2>
        <p style="font-size:12px;color:var(--muted-fg);margin:0;">@Model.Count() registros encontrados</p>
    </div>
    <a asp-action="Create" class="btn-sm-primary">
        <i class="fa-solid fa-plus"></i> Nuevo Siniestro
    </a>
</div>

<div class="sm-card" style="overflow:hidden;">
    <table class="sm-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tipo de Daño</th>
                <th>Dirección</th>
                <th>Estado</th>
                <th>Cliente</th>
                <th>Fecha Registro</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var estadoStr = item.Estado.ToString().ToLower();
                var badgeClass = estadoStr switch
                {
                    "levantamiento" => "badge-levantamiento",
                    "en proceso" => "badge-proceso",
                    "completado" => "badge-completado",
                    "cancelado" => "badge-cancelado",
                    "cerrado" => "badge-cerrado",
                    _ => "badge-proceso"
                };
                <tr>
                    <td><span class="id-badge">#@item.Id.ToString().PadLeft(3, '0')</span></td>
                    <td style="font-weight:600;">@item.TipoDanio</td>
                    <td style="color:var(--muted-fg);font-size:12px;">@item.Direccion</td>
                    <td>
                        <span class="badge-estado @badgeClass">
                            <span class="badge-dot"></span>
                            @item.Estado
                        </span>
                    </td>
                    <td>@(item.Cliente?.Nombre ?? "Sin asignar")</td>
                    <td style="font-size:12px;color:var(--muted-fg);font-family:monospace;">
                        @item.FechaRegistro.ToShortDateString()
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-sm-icon view" title="Ver">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-sm-icon edit" title="Editar">
                            <i class="fa-solid fa-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-sm-icon danger" title="Eliminar">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>