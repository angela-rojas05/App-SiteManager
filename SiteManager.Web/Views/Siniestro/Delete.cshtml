@model SiteManager.Domain.Models.Siniestro
@{
    ViewData["Title"] = "Eliminar Siniestro";
}

<div class="sm-delete-card">
    <div class="sm-delete-header">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <h2>¿Eliminar este siniestro?</h2>
    </div>
    <div class="sm-delete-body">
        <div class="sm-delete-row">
            <span>ID</span>
            <span style="font-family:monospace;">#@Model.Id.ToString().PadLeft(3, '0')</span>
        </div>
        <div class="sm-delete-row">
            <span>Tipo de Daño</span>
            <span>@Model.TipoDanio</span>
        </div>
        <div class="sm-delete-row">
            <span>Dirección</span>
            <span>@Model.Direccion</span>
        </div>
        <div class="sm-delete-row">
            <span>Estado</span>
            <span>@Model.Estado</span>
        </div>
        <div class="sm-delete-row">
            <span>Cliente</span>
            <span>@(Model.Cliente?.Nombre ?? "Sin asignar")</span>
        </div>
    </div>
    <div class="sm-delete-footer">
        <form asp-action="Delete" method="post" style="display:inline;">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-sm-danger"><i class="fa-solid fa-trash"></i> Eliminar</button>
        </form>
        <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
    </div>
</div>