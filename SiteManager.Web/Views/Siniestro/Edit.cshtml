@model SiteManager.Domain.Models.Siniestro
@{
    ViewData["Title"] = "Editar Siniestro";
}

<div class="sm-form-card">
    <div class="sm-form-header">
        <h2><i class="fa-solid fa-pencil" style="color:#d97706;margin-right:8px;"></i>Editar Siniestro <span style="font-family:monospace;color:var(--muted-fg);">#@Model.Id.ToString().PadLeft(3, '0')</span></h2>
        <p>Modifica los datos del expediente</p>
    </div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="FechaRegistro" />
        <div asp-validation-summary="ModelOnly" class="sm-field-error" style="padding:12px 24px;"></div>
        <div class="sm-form-body">
            <div class="sm-field">
                <label asp-for="TipoDanio">Tipo de Daño *</label>
                <input asp-for="TipoDanio" />
                <span asp-validation-for="TipoDanio" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="Direccion">Dirección *</label>
                <input asp-for="Direccion" />
                <span asp-validation-for="Direccion" class="sm-field-error"></span>
            </div>
            <div class="sm-field">
                <label asp-for="Descripcion">Descripción</label>
                <textarea asp-for="Descripcion"></textarea>
                <span asp-validation-for="Descripcion" class="sm-field-error"></span>
            </div>
            <div class="sm-field-row">
                <div class="sm-field">
                    <label asp-for="Estado">Estado</label>
                    <select asp-for="Estado" asp-items="Html.GetEnumSelectList<SiteManager.Domain.Models.EstadoSiniestro>()"></select>
                </div>
                <div class="sm-field">
                    <label asp-for="ClienteId">Cliente</label>
                    <select asp-for="ClienteId" asp-items='new SelectList(ViewBag.Clientes, "Id", "Nombre")'>
                        <option value="">— Seleccione un cliente —</option>
                    </select>
                    <span asp-validation-for="ClienteId" class="sm-field-error"></span>
                </div>
            </div>
            <div class="sm-field">
                <label asp-for="FechaCierre">Fecha de Cierre</label>
                <input asp-for="FechaCierre" type="date" />
            </div>
        </div>
        <div class="sm-form-footer">
            <button type="submit" class="btn-sm-primary"><i class="fa-solid fa-floppy-disk"></i> Guardar Cambios</button>
            <a asp-action="Index" class="btn-sm-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}